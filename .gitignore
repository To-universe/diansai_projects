# =========================
*.elf
*.hex
*.bin
*.map
*.lst
*.o
*.obj
*.d
*.a
*.lib

# Keep STM32CubeMX configuration files.
!*.ioc

# =========================
# TI Code Composer Studio / Eclipse
# =========================
.metadata/
.settings/
Debug/
Release/
target/

*.launch
*.out
*.pp
*.mk
*.opt
*.cmd.genlibs
*.stackdump

# Keep CCS project metadata.
!.project
!.cproject
!.ccsproject

# =========================
# Archived results
# Files placed under result/ are intentional records, such as
# firmware releases, test data, screenshots, and reports.
# =========================
!**/result/
!**/result/**
