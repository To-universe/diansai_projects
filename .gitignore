!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json

# =========================
# CMake
# =========================
build/
cmake-build-*/
CMakeFiles/
CMakeCache.txt
cmake_install.cmake
CTestTestfile.cmake
Makefile
compile_commands.json

